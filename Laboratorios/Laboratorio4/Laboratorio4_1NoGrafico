            " Funciones definidas: sigmoid(), lrCostFunction()\n",
            "\n",
            "Verificación sigmoide:\n",
            "  sigmoid( -10) = 0.0000\n",
            "  sigmoid(  -2) = 0.1192\n",
            "  sigmoid(   0) = 0.5000\n",
            "  sigmoid(   2) = 0.8808\n",
            "  sigmoid(  10) = 1.0000\n"
          ]
        }
      ],
      "source": [
        "def sigmoid(z):\n",
        "    \"\"\"Función sigmoide: transforma z en probabilidad [0,1].\"\"\"\n",
        "    return 1.0 / (1.0 + np.exp(-np.clip(z, -500, 500)))\n",
        "\n",
        "\n",
        "def lrCostFunction(theta, X, y, lambda_):\n",
        "    \"\"\"\n",
        "    Calcula la función de costo y el gradiente para regresión logística\n",
        "    con regularización L2.\n",
        "\n",
        "    Parámetros:\n",
        "        theta   : vector de parámetros (n+1,)\n",
        "        X       : matriz de características con bias (m, n+1)\n",
        "        y       : etiquetas binarias (m,)\n",
        "        lambda_ : parámetro de regularización\n",
        "\n",
        "    Retorna:\n",
        "        J    : valor escalar del costo\n",
        "        grad : vector gradiente (n+1,)\n",
        "    \"\"\"\n",
        "    m = y.size\n",
        "    if y.dtype == bool:\n",
        "        y = y.astype(int)\n",
        "\n",
        "    h = sigmoid(X.dot(theta))\n",
        "\n",
        "    temp = theta.copy()\n",
        "    temp[0] = 0  # el término de sesgo no se regulariza\n",
        "\n",
        "    J = (1/m) * np.sum(-y * np.log(h + 1e-15) - (1-y) * np.log(1 - h + 1e-15)) \\\n",
        "        + (lambda_ / (2*m)) * np.sum(np.square(temp))\n",
        "\n",
        "    grad = (1/m) * X.T.dot(h - y) + (lambda_/m) * temp\n",
        "\n",
        "    return J, grad\n",
        "\n",
        "\n",
        "print(' Funciones definidas: sigmoid(), lrCostFunction()')\n",
        "\n",
        "# ── Verificación rápida de la sigmoide ────────────────────────────────────────\n",
        "valores_z = np.array([-10, -2, 0, 2, 10])\n",
        "print(f'\\nVerificación sigmoide:')\n",
        "for z in valores_z:\n",
        "    print(f'  sigmoid({z:4d}) = {sigmoid(z):.4f}')"
      ]
