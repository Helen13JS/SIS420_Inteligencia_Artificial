      "source": [
        "# ── Paso 1: Filtrar clases con > 5000 ejemplos ───────────────────────────────\n",
        "counts = df_completo[y_label_col].value_counts()\n",
        "clases_validas = counts[counts > 5000].index\n",
        "df_filtrado = df_completo[df_completo[y_label_col].isin(clases_validas)].copy()\n",
        "print(f'Clases seleccionadas: {sorted(clases_validas.tolist())}')\n",
        "print(f'Muestras tras filtro: {len(df_filtrado):,}')\n",
        "\n",
        "# ── Paso 2: Balanceo (oversampling al máximo de la clase más frecuente) ───────\n",
        "n_por_clase = df_filtrado[y_label_col].value_counts().max()\n",
        "df_balanced = (\n",
        "    df_filtrado\n",
        "    .groupby(y_label_col, group_keys=False)\n",
        "    .apply(lambda x: x.sample(n=n_por_clase, replace=True, random_state=42),\n",
        "           include_groups=True)\n",
        "    .reset_index(drop=True)\n",
        ")\n",
        "print(f'\\nMuestras por clase tras balanceo:')\n",
        "print(df_balanced[y_label_col].value_counts())\n",
        "\n",
        "# ── Paso 3: Separación de X e y ───────────────────────────────────────────────\n",
        "X_all = df_balanced.drop(columns=[y_label_col]).values.astype(float)\n",
        "y_all = df_balanced[y_label_col].values\n",
        "\n",
        "# ── Paso 4: Mapeo de etiquetas a 0, 1, 2, ... ────────────────────────────────\n",
        "unique_labels = np.sort(np.unique(y_all))\n",
        "mapping = {label: i for i, label in enumerate(unique_labels)}\n",
        "inv_mapping = {i: label for label, i in mapping.items()}\n",
        "y_mapped = np.array([mapping[l] for l in y_all])\n",
        "num_labels = len(unique_labels)\n",
        "\n",
        "print(f'\\nMapeo de clases: {mapping}')\n",
        "print(f'Número de clases: {num_labels}')\n",
        "\n",
        "# ── Paso 5: División 80/20 ────────────────────────────────────────────────────\n",
        "m_total = len(y_mapped)\n",
        "indices = np.random.permutation(m_total)\n",
        "train_size = int(0.8 * m_total)\n",
        "\n",
        "X_train_raw = X_all[indices[:train_size]]\n",
        "X_test_raw  = X_all[indices[train_size:]]\n",
        "y_train     = y_mapped[indices[:train_size]]\n",
        "y_test      = y_mapped[indices[train_size:]]\n",
        "\n",
        "# ── Paso 6: Normalización Z-score (calculada SOLO sobre entrenamiento) ────────\n",
        "# IMPORTANTE: la media y std se calculan solo con X_train para evitar fuga de datos\n",
        "mu    = X_train_raw.mean(axis=0)\n",
        "sigma = X_train_raw.std(axis=0)\n",
        "sigma[sigma == 0] = 1  # evitar división por cero en columnas constantes\n",
        "\n",
        "X_train = (X_train_raw - mu) / sigma\n",
        "X_test  = (X_test_raw  - mu) / sigma  # se aplica la misma escala del train\n",
        "\n",
        "print('\\n' + '='*50)\n",
        "print('RESUMEN DEL PREPROCESAMIENTO')\n",
        "print('='*50)\n",
        "print(f'Total muestras balanceadas : {m_total:,}')\n",
        "print(f'Entrenamiento (80%)        : {X_train.shape[0]:,}')\n",
        "print(f'Prueba (20%)               : {X_test.shape[0]:,}')\n",
        "print(f'Propiedades (n)            : {X_train.shape[1]}')\n",
        "print(f'Clases (num_labels)        : {num_labels}')\n",
        "print(f'Rango X_train (tras norm.) : [{X_train.min():.2f}, {X_train.max():.2f}]')"
      ]
