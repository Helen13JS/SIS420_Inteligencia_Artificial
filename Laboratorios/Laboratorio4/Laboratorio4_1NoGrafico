      "source": [
        "def OneVsAll_ConCosto(X, y, num_labels, lambda_, max_iter=400):\n",
        "    \"\"\"\n",
        "    Entrena num_labels clasificadores binarios (One-vs-All).\n",
        "    Registra el historial de costo para cada clasificador.\n",
        "\n",
        "    Retorna:\n",
        "        all_theta    : matriz (num_labels, n+1) con todos los parámetros\n",
        "        historial    : lista de listas con costos por iteración por clase\n",
        "        costos_final : costo final de cada clasificador\n",
        "    \"\"\"\n",
        "    m, n = X.shape\n",
        "    X_bias = np.concatenate([np.ones((m, 1)), X], axis=1)  # agrega columna de 1s\n",
        "    all_theta = np.zeros((num_labels, n + 1))\n",
        "    costos_inicio = []\n",
        "    costos_final  = []\n",
        "\n",
        "    for c in range(num_labels):\n",
        "        y_binario = (y == c).astype(int)\n",
        "        theta_init = np.zeros(n + 1)\n",
        "\n",
        "        # Costo inicial (antes de optimizar)\n",
        "        J_init, _ = lrCostFunction(theta_init, X_bias, y_binario, lambda_)\n",
        "        costos_inicio.append(J_init)\n",
        "\n",
        "        # Optimización\n",
        "        res = optimize.minimize(\n",
        "            lrCostFunction,\n",
        "            theta_init,\n",
        "            args=(X_bias, y_binario, lambda_),\n",
        "            jac=True,\n",
        "            method='CG',\n",
        "            options={'maxiter': max_iter, 'disp': False}\n",
        "        )\n",
        "\n",
        "        all_theta[c] = res.x\n",
        "        costos_final.append(res.fun)\n",
        "\n",
        "        print(f'  Clase {c} (Modo {inv_mapping[c]}): '\n",
        "              f'Costo inicial={J_init:.4f} → Costo final={res.fun:.4f} '\n",
        "              f'| Convergió: {res.success}')\n",
        "\n",
        "    return all_theta, costos_inicio, costos_final\n",
        "\n",
        "\n",
        "# ── Entrenamiento ──────────────────────────────────────────────────────────────\n",
        "lambda_ = 0.1\n",
        "print('Entrenando modelo One-vs-All...')\n",
        "print(f'  Parámetros: λ={lambda_}, maxiter=400, método=CG')\n",
        "print(f'  Clasificadores a entrenar: {num_labels}')\n",
        "print()\n",
        "\n",
        "all_theta, costos_inicio, costos_final = OneVsAll_ConCosto(\n",
        "    X_train, y_train, num_labels, lambda_, max_iter=400\n",
        ")\n",
        "\n",
        "print()\n",
        "print(f' Entrenamiento completado. all_theta shape: {all_theta.shape}')"
      ]
